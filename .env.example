# Copy this file to .env and fill in the values.
#   cp .env.example .env
# .env is gitignored — NEVER commit it.

# Timezone for the gateway
TZ=Europe/Paris

# Control-UI / gateway auth token.
# Generate a strong random value:
#   openssl rand -hex 32
# Paste it in the browser at http://127.0.0.1:18789 (Settings) to access the UI.
OPENCLAW_GATEWAY_TOKEN=

# ---- Optional provider keys ------------------------------------------------
# In OpenClaw 2026.x these are normally set during onboarding and stored under
# data/openclaw/credentials + auth-profiles.json, so you usually DON'T need them
# here. Uncomment only if you prefer injecting a key via the environment.
# OPENROUTER_API_KEY=
# TAVILY_API_KEY=
# ANTHROPIC_API_KEY=

# ---- Optional: only if you keep the custom `jx76-gog` skill -----------------
# GOG_KEYRING_PASSWORD=
